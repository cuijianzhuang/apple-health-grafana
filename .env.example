# ============================================================
#  Apple Health Grafana — 环境变量配置
#  复制此文件为 .env 并按需修改
#  cp .env.example .env
# ============================================================

# ---------- Grafana ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=health
GRAFANA_PORT=3000

# ---------- InfluxDB ----------
INFLUX_DB=health

# ---------- Health Auto Export API ----------
API_PORT=5353
# 设置后客户端必须在 Header 中携带 X-API-Key（留空则不鉴权）
API_KEY=
