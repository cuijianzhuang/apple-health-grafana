# ============================================================
#  Apple Health Grafana — 环境变量配置
#  复制此文件为 .env 并按需修改
#  cp .env.example .env
# ============================================================

# ---------- Grafana ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=health
GRAFANA_PORT=3000
# 公开访问地址，用于生成分享/公开仪表板链接
# 示例：http://1.2.3.4:3000 或 https://health.example.com
GRAFANA_ROOT_URL=http://localhost:3000

# ---------- InfluxDB ----------
INFLUX_DB=health

# ---------- Health Auto Export API ----------
API_PORT=5353
# 设置后客户端必须在 Header 中携带 X-API-Key（留空则不鉴权）
API_KEY=
